rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    // Server-only fields on the user document. Cloud Functions use the
    // Admin SDK and bypass these rules; clients are blocked from mutating
    // these fields directly.
    function userServerFieldsUntouched() {
      return !(request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['credits',
                         'lastPurchaseToken',
                         'mergedFromAnonymousUid',
                         'mergedToUid']));
    }

    function userCreateHasNoServerFields() {
      return !(request.resource.data.keys()
                .hasAny(['credits',
                         'lastPurchaseToken',
                         'mergedFromAnonymousUid',
                         'mergedToUid']));
    }

    match /users/{userId} {
      allow read: if isAuthed() && request.auth.uid == userId;
      // Client may create their own user doc but cannot seed server-only fields.
      allow create: if isAuthed() && request.auth.uid == userId
                    && userCreateHasNoServerFields();
      // Client may update display preferences but NOT credit/purchase/merge fields.
      allow update: if isAuthed() && request.auth.uid == userId
                    && userServerFieldsUntouched();
      allow delete: if false;

      // Existing history collection — preserved as-is for production code at
      // backend/functions/src/index.ts:282 (/v1/history/add) and :315 (/v1/history/list).
      match /history/{historyId} {
        allow read, write: if isAuthed() && request.auth.uid == userId;
      }

      // New: append-only credit ledger written exclusively by server (Admin SDK).
      // Named `creditLog` to disambiguate from the top-level `/upscaleTransactions`
      // collection used by the staging/commit flow.
      match /creditLog/{logId} {
        allow read: if isAuthed() && request.auth.uid == userId;
        allow write: if false;  // server-only
      }
    }

    // Existing top-level collection used by /v1/credits/{stage,commit,refund}
    // (backend/functions/src/index.ts:128, 200, 247). Server writes via Admin SDK;
    // clients may read their own transactions for UI display.
    match /upscaleTransactions/{txId} {
      allow read: if isAuthed() && resource.data.uid == request.auth.uid;
      allow write: if false;  // server-only (Admin SDK bypasses)
    }

    // New: public pricing document, written by scheduled/cron Cloud Function.
    match /pricing/current {
      allow read: if true;
      allow write: if false;  // server-only (cron)
    }

    // RC17: support / feedback tickets. One-way write — clients can
    // CREATE their own ticket (uid pinned to auth.uid, no server-only
    // status field), but never read, update, or delete. The backend
    // reads via Admin SDK to triage. The shape is:
    //   {uid, email?, displayName?, isAnonymous, subject, category,
    //    description, diagnosticsIncluded, createdAt,
    //    device?, debugLogTail?}
    match /support/{ticketId} {
      allow create: if isAuthed()
                    && request.resource.data.uid == request.auth.uid
                    && !('status' in request.resource.data.keys())
                    && !('triagedAt' in request.resource.data.keys())
                    && !('assignedTo' in request.resource.data.keys());
      allow read, update, delete: if false;
    }
  }
}
