rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if isAuthed() && request.auth.uid == userId;

      match /history/{historyId} {
        allow read, write: if isAuthed() && request.auth.uid == userId;
      }
    }

    match /upscaleTransactions/{txId} {
      allow read, write: if isAuthed() && resource.data.uid == request.auth.uid;
      allow create: if isAuthed() && request.resource.data.uid == request.auth.uid;
    }
  }
}
