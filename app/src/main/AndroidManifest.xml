<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.posterpdf">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <!-- Phase G3: Google Play Billing Library v7. Required for BillingClient + launchBillingFlow. -->
    <uses-permission android:name="com.android.vending.BILLING" />
    <!-- RC11: foreground service so the on-device upscaler can survive
         backgrounding / Doze / Samsung's PPK without being killed mid-run.
         FOREGROUND_SERVICE is auto-granted; the dataSync subtype reflects
         the work being done (image processing + writing partial output
         to cache between tiles). POST_NOTIFICATIONS gates the progress
         notification on Android 13+ — runtime-prompted on first upscale. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PosterPDF">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- RC11: foreground service that hosts the on-device ESRGAN upscale
             so PPK / Doze can\'t kill it. dataSync is the appropriate
             foregroundServiceType for image processing + cache writes. -->
        <service
            android:name=".ml.UpscaleForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>

</manifest>
