<?xml version="1.0" encoding="utf-8"?>
<!--
  Premium model icon: 4-pointed sparkle/star — used for TOPAZ_4X and TOPAZ_8X.
  Horizontal and vertical diamond arms plus diagonal smaller arms give the
  classic AI-sparkle silhouette without using any brand asset.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!--
      RC8: removed the white inner highlight. At 100dp render size in the
      model card, the small inner star rendered as a tiny white square
      that the user read as a "white rectangle in the middle of the card."
      Single-color star is cleaner.
    -->
    <path
        android:fillColor="#FFF4B400"
        android:pathData="M12,2 L13.5,10.5 L22,12 L13.5,13.5 L12,22 L10.5,13.5 L2,12 L10.5,10.5 Z" />
</vector>
