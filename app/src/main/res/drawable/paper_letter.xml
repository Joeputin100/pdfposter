        android:pathData="M110,83.55 L290,83.55 A6,6 0 0 1 296,89.55 L296,310.45 A6,6 0 0 1 290,316.45 L110,316.45 A6,6 0 0 1 104,310.45 L104,89.55 A6,6 0 0 1 110,83.55 Z"
        android:fillColor="#FFFFFFFF" />

    <!-- 1-inch grid lines (8.5 wide => 8 vertical interior lines, 11 tall => 10 horizontal) -->
    <!-- Vertical interior grid lines at 1 inch spacing (21.18 units) -->
    <path android:pathData="M125.18,83.55 L125.18,316.45" android:strokeColor="#1A000000" android:strokeWidth="0.6" />
