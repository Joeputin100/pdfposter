<!--
  Clarus the Dogcow — landscape orientation. The same traced silhouette
  rotated 90 degrees clockwise so the dogcow lies on its side, indicating
  landscape page orientation.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    <!--
      RC10 — viewport bumped 180×180 → 200×200 with 10dp padding on every
      side. RC8\'s 180×180 was technically fine (rotated content spans
      X∈[26,154], Y∈[8,172] inside it) but the user reported the top of
      Clarus\'s head was being clipped on their device. Adding margin to
      the drawable directly is more robust than chasing the right Icon
      modifier — Compose\'s Icon scales the painter to its modifier size
      preserving aspect ratio, so a square 200×200 vector with 10dp
      padding centers cleanly in any square Modifier.size().

      Centering the same rotated content (spans X∈[4,132], Y∈[12,176]
      after rotate around (100, 100)) in the new 200×200 viewport:
        translateX = 100 - (4+132)/2 = +32
        translateY = 100 - (12+176)/2 = +6
      Final span: X ∈ [36, 164], Y ∈ [18, 182] — 18dp clearance on every
      side so no edge of Clarus reaches the viewport boundary.
    -->
    <group
        android:pivotX="100.0"
        android:pivotY="100.0"
        android:rotation="90"
        android:translateX="32.0"
        android:translateY="6.0">
        <path
            android:fillColor="#FF1F1F1F"
            android:pathData="M28,4h8v4h-8zM52,4h12v4h-12zM24,8h4v16h-4zM36,8h4v4h-4zM36,24h4v4h-4zM36,124h4v4h-4zM48,8h4v4h-4zM60,8h4v8h-4zM60,32h4v4h-4zM60,116h4v8h-4zM36,12h12v4h-12zM160,12h4v4h-4zM160,44h4v4h-4zM52,16h8v16h-8zM52,124h8v4h-8zM160,16h8v8h-8zM20,24h4v4h-4zM156,24h4v4h-4zM156,48h4v8h-4zM156,84h4v32h-4zM164,24h4v20h-4zM16,28h4v4h-4zM152,28h4v4h-4zM152,56h4v28h-4zM152,116h4v8h-4zM8,32h8v4h-8zM144,32h8v4h-8zM144,124h8v4h-8zM4,36h4v12h-4zM64,36h8v8h-8zM140,36h4v8h-4zM72,44h68v4h-68zM8,48h32v4h-32zM88,48h44v4h-44zM40,52h4v12h-4zM40,116h4v8h-4zM92,52h40v4h-40zM100,56h24v8h-24zM44,64h8v4h-8zM44,84h8v4h-8zM44,68h16v16h-16zM44,88h4v28h-4zM68,88h56v4h-56zM64,92h4v24h-4zM124,92h8v4h-8zM124,124h8v4h-8zM132,96h4v8h-4zM132,116h4v8h-4zM136,104h4v12h-4zM40,128h12v4h-12zM132,128h12v4h-12z" />
