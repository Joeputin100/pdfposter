# Android
**/build/
*.apk

# Node / Firebase backend
backend/functions/node_modules/
backend/functions/lib/
backend/functions/.secrets.local

# Local env / secrets
*.env
*.env.local

# Signing material — keep out of source control.
# release.keystore is fetched from GCS at Cloud Build time; never commit.
*.keystore
*.jks
*.p12
release.keystore
keystore_gen.yaml

# Firebase client config — fetched from GCS at Cloud Build time, same pattern
# as release.keystore. Real google-services.json contains an OAuth client ID
# and project identifiers we don't want in a public repo.
google-services.json
app/google-services.json

# IDE
.idea/
.vscode/

# Coding-agent session transcripts (opencode etc.)
session-*.md
